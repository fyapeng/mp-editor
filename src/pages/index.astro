        for (const file of Array.from(files)) {
          if (!file.type.startsWith("image/")) continue;
          const id = crypto.randomUUID();
          await saveAsset(id, file, file.name);
          insertAtCursor(`\n\n![${file.name.replace(/\.[^.]+$/, "")}](${ASSET_SCHEME}${id})\n\n`);
