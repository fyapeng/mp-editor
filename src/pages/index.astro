      $("#download-html").addEventListener("click", () => download(`${titleInput.value || "wechat-article"}.html`, `<!doctype html><meta charset="utf-8">${phone.outerHTML}`, "text/html;charset=utf-8"));

      let mathJaxPromise: Promise<any> | null = null;
      const ensureMathJax = () => {
        const active = (window as any).MathJax;
        if (typeof active?.tex2svg === "function") return Promise.resolve(active);
        if (mathJaxPromise) return mathJaxPromise;
        mathJaxPromise = new Promise((resolve, reject) => {
          (window as any).MathJax = {
            tex: { tags: "ams" },
            svg: { fontCache: "none" },
            startup: { typeset: false },
          };
          const script = document.createElement("script");
          script.src = "https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js";
          script.onload = async () => {
            const mathJax = (window as any).MathJax;
            await (mathJax.startup?.promise || Promise.resolve());
            resolve(mathJax);
          };
          script.onerror = () => {
            mathJaxPromise = null;
            reject(new Error("MathJax 加载失败"));
          };
          document.head.append(script);
        });
        return mathJaxPromise;
      };

      const prepareImagesForCopy = async (root: HTMLElement) => {
        for (const image of root.querySelectorAll<HTMLImageElement>("img[data-asset-id]")) {
          const blob = assetBlobs.get(image.dataset.assetId || "");
          if (blob) image.src = await blobToDataUrl(blob);
          image.removeAttribute("data-asset-id");
        }
      };

      const svgToPngDataUrl = async (svg: SVGSVGElement) => {
        const parseEx = (value: string | null, fallback: number) => {
          const number = Number.parseFloat(value || "");
          return Number.isFinite(number) ? number * 9 : fallback;
        };
        const viewBox = (svg.getAttribute("viewBox") || "").trim().split(/\s+/).map(Number);
        const ratio = viewBox.length === 4 && viewBox[2] > 0 && viewBox[3] > 0 ? viewBox[2] / viewBox[3] : 3;
        let cssHeight = parseEx(svg.getAttribute("height"), 28);
        let cssWidth = parseEx(svg.getAttribute("width"), cssHeight * ratio);
        if (cssWidth > 620) {
          cssHeight *= 620 / cssWidth;
          cssWidth = 620;
        }
        cssWidth = Math.max(24, Math.ceil(cssWidth));
        cssHeight = Math.max(18, Math.ceil(cssHeight));
        const scale = 3;
        const copy = svg.cloneNode(true) as SVGSVGElement;
        copy.setAttribute("width", String(cssWidth * scale));
        copy.setAttribute("height", String(cssHeight * scale));
        copy.style.cssText = "display:block;color:#1d2421;background:transparent;";
        copy.setAttribute("fill", "#1d2421");
        copy.querySelectorAll("g").forEach((group) => {
          group.setAttribute("fill", "#1d2421");
          group.setAttribute("stroke", "#1d2421");
        });
        const source = new XMLSerializer().serializeToString(copy);
        const url = URL.createObjectURL(new Blob([source], { type: "image/svg+xml;charset=utf-8" }));
        try {
          const image = new Image();
          image.decoding = "async";
          image.src = url;
          await image.decode();
          const canvas = document.createElement("canvas");
          canvas.width = cssWidth * scale;
          canvas.height = cssHeight * scale;
          const context = canvas.getContext("2d");
          if (!context) throw new Error("无法创建公式画布");
          context.drawImage(image, 0, 0, canvas.width, canvas.height);
          return { dataUrl: canvas.toDataURL("image/png"), width: cssWidth, height: cssHeight };
        } finally {
          URL.revokeObjectURL(url);
        }
      };

      const prepareFormulasForCopy = async (root: HTMLElement) => {
        const formulas = [...root.querySelectorAll<HTMLElement>(".formula-block, .formula-inline")];
        if (!formulas.length) return;
        $("#save-status").textContent = "正在生成微信公式…";
        const mathJax = await ensureMathJax();
        for (const formula of formulas) {
          const display = formula.classList.contains("formula-block");
          const source = formula.dataset.mathSource || "";
          mathJax.texReset?.();
          const container = mathJax.tex2svg(source, { display });
          const svg = container.querySelector("svg") as SVGSVGElement | null;
          if (!svg) continue;
          if (display) {
            const png = await svgToPngDataUrl(svg);
            const image = document.createElement("img");
            image.src = png.dataUrl;
            image.alt = "公式";
            image.width = png.width;
            image.height = png.height;
            image.style.cssText = `display:block;width:${png.width}px;max-width:100%;height:auto;margin:0 auto;padding:0;border:0;`;
            formula.replaceWith(image);
            continue;
          }
          const width = svg.style.minWidth || svg.getAttribute("width") || "";
          svg.removeAttribute("width");
          svg.setAttribute("xmlns", "http://www.w3.org/2000/svg");
          svg.style.cssText = `display:initial;max-width:300vw;flex-shrink:0;width:${width};color:currentColor;`;
          svg.setAttribute("fill", "currentColor");
          svg.querySelectorAll("g").forEach((group) => {
            group.setAttribute("fill", "currentColor");
            group.setAttribute("stroke", "currentColor");
          });
          const wrapper = document.createElement(display ? "section" : "span");
          wrapper.className = display ? "mp-formula-block" : "mp-formula-inline";
          wrapper.style.cssText = display
            ? "box-sizing:border-box;display:block;margin:0;padding:0;overflow-x:auto;overflow-y:hidden;color:#1d2421;text-align:center;font-size:0;line-height:0;"
            : "display:inline-block;margin:0 2px;color:#1d2421;font-size:1em;line-height:1.2;vertical-align:-0.15em;";
          wrapper.append(svg);
          formula.replaceWith(wrapper);
        }
      };

      const copyRichText = async () => {
        const clone = phone.cloneNode(true) as HTMLElement;
        clone.classList.remove("is-mobile");
        clone.style.cssText = "width:100%;max-width:677px;margin:0 auto;padding:0;background:#fff;color:#242927;";
        await prepareImagesForCopy(clone);
        await prepareFormulasForCopy(clone);
        const html = `<section style="width:100%;max-width:677px;margin:0 auto;background:#fff;">${clone.innerHTML}</section>`;
        try {
          await navigator.clipboard.write([new ClipboardItem({
            "text/html": new Blob([html], { type: "text/html" }),
            "text/plain": new Blob([phone.innerText], { type: "text/plain" }),
          })]);
          $("#save-status").textContent = "富文本已复制";
          showToast("已复制公式富文本，可粘贴到公众号后台");
        } catch (error) {
          console.error(error);
          const selection = window.getSelection();
          const range = document.createRange();
          range.selectNodeContents(phone);
          selection?.removeAllRanges();
          selection?.addRange(range);
          document.execCommand("copy");
          selection?.removeAllRanges();
          showToast("已通过兼容方式复制富文本");
        }
      };

      $("#copy-rich").addEventListener("click", copyRichText);

      const setHelperState = (state: "idle" | "ready" | "error", message: string, detail: string, enabled = false) => {
        helperStatus.className = `helper-status${state === "ready" ? " is-ready" : state === "error" ? " is-error" : ""}`;
        helperStatus.innerHTML = `<span></span>${message}`;
        helperDetail.textContent = detail;
        helperPreviewButton.disabled = !enabled;
        helperSubmitButton.disabled = !enabled;
      };

      const checkLocalHelper = async () => {
        setHelperState("idle", "正在检测本地助手…", "检查 127.0.0.1:4399");
        try {
          const response = await fetch(`${HELPER_URL}/api/status`, { mode: "cors" });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const status = await response.json();
          saveWechatConfigButton.disabled = !status.originAllowed;
          queryPublicIpButton.disabled = !status.originAllowed;
          if (status.appIdHint) appIdInput.placeholder = `已配置：${status.appIdHint}`;
          if (!status.configured) {
            setHelperState("error", "已连接，但公众号尚未配置", "请在本地项目的 .env 中填写 WECHAT_APP_ID 和 WECHAT_APP_SECRET。");
            return status;
          }
          const allowed = status.originAllowed || location.origin === HELPER_URL;
          setHelperState(
            allowed ? "ready" : "error",
            allowed ? "本地助手已就绪" : "本地助手未授权当前网页",
            allowed ? `公众号 AppID：${status.appIdHint}` : `请把 ${location.origin} 加入 LOCAL_ALLOWED_ORIGINS。`,
            allowed,
          );
          return status;
        } catch (error) {
          console.error(error);
          setHelperState("error", "未发现本地助手", "先下载项目并运行 npm run local，然后重新检测。");
          return null;
        }
      };

      const sendDraftRequest = async (dryRun: boolean) => {
        if (!coverPreview.src || !coverPreview.classList.contains("is-visible")) {
          showToast("请先选择草稿封面图片");
          return;
        }
        const action = dryRun ? "执行接口预检查" : updateMediaInput.value.trim() ? "更新已有草稿" : "新增公众号草稿";
        if (!dryRun && !window.confirm(`确认${action}《${titleInput.value}》？操作只写入草稿箱，不会群发。`)) return;
        helperPreviewButton.disabled = true;
        helperSubmitButton.disabled = true;
        setHelperState("idle", dryRun ? "正在生成本地预览…" : "正在写入公众号草稿箱…", "公式编译和图片上传可能需要一些时间。");
        try {
          const markdown = await markdownForExport(input.value);
          const response = await fetch(`${HELPER_URL}/api/draft`, {
            method: "POST",
            mode: "cors",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              dryRun,
              markdown,
              coverDataUrl: coverPreview.src,
              title: titleInput.value,
              author: authorInput.value,
              digest: digestInput.value,
              sourceUrl: sourceInput.value,
              coverCaption: captionInput.value,
              updateMediaId: updateMediaInput.value.trim(),
            }),
          });
          const result = await response.json();
          if (!response.ok || !result.ok) throw new Error(result.error || `HTTP ${response.status}`);
          if (result.mediaId) updateMediaInput.value = result.mediaId;
          setHelperState("ready", dryRun ? "本地预检查完成" : "草稿箱写入成功", result.message, true);
          showToast(dryRun ? "预检查完成，请查看本地 output 目录" : "草稿已写入，请到公众号后台预览");
        } catch (error) {
          console.error(error);
          setHelperState("error", "草稿操作失败", error instanceof Error ? error.message : String(error), true);
        }
      };

      $("#check-helper").addEventListener("click", checkLocalHelper);
      $("#open-draft-panel").addEventListener("click", () => {
        const card = $("#draft-card");
        card.scrollIntoView({ behavior: "smooth", block: "start" });
        card.classList.remove("is-highlighted");
        requestAnimationFrame(() => card.classList.add("is-highlighted"));
        window.setTimeout(() => card.classList.remove("is-highlighted"), 1200);
        checkLocalHelper();
      });
      saveWechatConfigButton.addEventListener("click", async () => {
        if (!appIdInput.value.trim() || !appSecretInput.value.trim()) {
          showToast("请完整填写 AppID 和 AppSecret");
          return;
        }
        saveWechatConfigButton.disabled = true;
        try {
          const response = await fetch(`${HELPER_URL}/api/config`, {
            method: "POST",
            mode: "cors",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              appId: appIdInput.value.trim(),
              appSecret: appSecretInput.value.trim(),
            }),
          });
          const result = await response.json();
          if (!response.ok || !result.ok) throw new Error(result.error || `HTTP ${response.status}`);
          appSecretInput.value = "";
          appIdInput.value = "";
          showToast("公众号配置已保存到本机");
          await checkLocalHelper();
        } catch (error) {
          showToast(error instanceof Error ? error.message : String(error));
          saveWechatConfigButton.disabled = false;
        }
      });
      queryPublicIpButton.addEventListener("click", async () => {
        queryPublicIpButton.disabled = true;
        publicIpInput.value = "查询中…";
        try {
          const response = await fetch(`${HELPER_URL}/api/public-ip`, { mode: "cors" });
          const result = await response.json();
          if (!response.ok || !result.ok) throw new Error(result.error || `HTTP ${response.status}`);
          publicIpInput.value = result.ip;
          showToast("请把该 IP 加入公众号接口白名单");
        } catch (error) {
          publicIpInput.value = "";
          showToast(error instanceof Error ? error.message : String(error));
        } finally {
          queryPublicIpButton.disabled = false;
        }
      });
      helperPreviewButton.addEventListener("click", () => sendDraftRequest(true));
      helperSubmitButton.addEventListener("click", () => sendDraftRequest(false));
      window.setTimeout(checkLocalHelper, 600);

      document.addEventListener("keydown", (event) => {
        if (!(event.ctrlKey || event.metaKey)) return;
        if (event.key.toLowerCase() === "s") {
          event.preventDefault();
          $("#save-snapshot").click();
        }
        if (event.shiftKey && event.key.toLowerCase() === "c") {
          event.preventDefault();
          copyRichText();
        }
      });
    </script>
  </body>
</html>
