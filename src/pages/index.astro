      const currentState = () => ({
        markdown: input.value,
        title: titleInput.value,
        author: authorInput.value,
        digest: digestInput.value,
        source: sourceInput.value,
        caption: captionInput.value,
        accent: accentInput.value,
        theme: themeInput.value,
