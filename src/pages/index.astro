---
import "../styles/global.css";
import "katex/dist/katex.min.css";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="申椿 MP Editor：面向微信公众号的 Markdown 编辑、公式排版、兼容性检查和草稿上传工具" />
    <title>申椿 · MP Editor</title>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div class="brand">
          <p class="eyebrow">Markdown for WeChat Official Accounts</p>
          <h1>申椿 · MP Editor</h1>
        </div>
        <div class="actions">
          <label class="button">载入 Markdown<input id="file-input" type="file" accept=".md,.markdown,text/markdown" hidden /></label>
          <button class="button" id="download-md" type="button">导出 Markdown</button>
          <button class="button" id="download-html" type="button">导出 HTML</button>
          <button class="button button--draft" id="open-draft-panel" type="button">公众号草稿箱</button>
          <button class="button button--primary" id="copy-rich" type="button">复制到公众号</button>
        </div>
      </header>

      <section class="workspace">
        <aside class="panel sidebar">
          <section class="card">
            <h3>文章设置</h3>
            <label class="field"><span>标题</span><input id="title" value="未命名文章" /></label>
            <label class="field"><span>作者</span><input id="author" value="Sencium" /></label>
            <label class="field"><span>摘要</span><textarea id="digest"></textarea></label>
            <label class="field"><span>阅读原文</span><input id="source-url" type="url" placeholder="https://..." /></label>
            <label class="field"><span>封面图片</span><input id="cover-input" type="file" accept="image/png,image/jpeg,image/webp" /></label>
            <label class="field"><span>封图说明与来源</span><textarea id="cover-caption">《Drone Attacks in Beirut》，Murat Şengül 摄，Anadolu Agency，2024年9月29日；2025 World Press Photo 获奖作品。</textarea></label>
          </section>

          <section class="card draft-card" id="draft-card">
            <div class="card-title-row">
              <h3>公众号草稿箱</h3>
              <button class="text-button" id="check-helper" type="button">检测</button>
            </div>
            <p class="helper-status" id="helper-status"><span></span>尚未检测本地助手</p>
            <details class="helper-config">
              <summary>我的公众号配置</summary>
              <div class="setup-guide">
                <strong>在哪里找这些信息？</strong>
                <ol>
                  <li>登录微信公众平台，进入“设置与开发”。</li>
                  <li>打开“基本配置”或“开发接口管理”。</li>
                  <li>复制开发者 ID（AppID），查看或重置开发者密码（AppSecret）。</li>
                  <li>在“IP 白名单”中点击查看或修改，添加下方查询出的 IPv4 地址。</li>
                </ol>
                <a href="https://github.com/fyapeng/mp-editor/blob/main/docs/configuration.md" target="_blank" rel="noreferrer">查看完整配置指南</a>
              </div>
              <label class="field"><span>AppID</span><input id="wechat-app-id" autocomplete="off" placeholder="在公众号后台复制" /></label>
              <label class="field"><span>AppSecret</span><input id="wechat-app-secret" type="password" autocomplete="new-password" placeholder="只写入本机，不会上传 GitHub" /></label>
              <div class="ip-row">
                <label class="field"><span>接口出口 IP</span><input id="public-ip" readonly placeholder="由本地助手查询" /></label>
                <button class="button" id="query-public-ip" type="button" disabled>查询</button>
              </div>
              <button class="button button--wide" id="save-wechat-config" type="button" disabled>保存到本机</button>
              <p class="audit-message">AppID 与 AppSecret 只发送到 127.0.0.1，并写入本机被 Git 忽略的 .env。</p>
            </details>
            <label class="field"><span>更新已有草稿（可选 media_id）</span><input id="update-media-id" placeholder="留空则新增草稿" /></label>
            <div class="helper-actions">
              <button class="button" id="draft-preview" type="button" disabled>接口预检查</button>
              <button class="button button--primary" id="draft-submit" type="button" disabled>写入草稿箱</button>
            </div>
            <a class="helper-link" id="open-helper" href="http://127.0.0.1:4399/" target="_blank" rel="noreferrer">打开本地发布模式</a>
            <p class="audit-message" id="helper-detail">Pages 不保存公众号密钥；发布请求由本机助手处理。</p>
          </section>

          <section class="card">
            <h3>版式</h3>
            <label class="field"><span>主题</span>
              <select id="theme">
                <option value="ink">墨黑 · 学术</option>
                <option value="red">朱砂 · 人文</option>
                <option value="blue">深蓝 · 清晰</option>
                <option value="green">松绿 · 素雅</option>
              </select>
            </label>
            <label class="field"><span>自定义主题色</span><input id="accent" type="color" value="#0b1015" /></label>
            <label class="field"><span>正文外链</span>
              <select id="link-mode">
                <option value="text">仅保留文字（推荐）</option>
                <option value="keep">保留链接</option>
                <option value="footnote">转为文末链接</option>
              </select>
            </label>
            <div class="segmented" aria-label="预览宽度">
              <button class="is-active" data-width="desktop" type="button">桌面</button>
              <button data-width="mobile" type="button">手机</button>
            </div>
          </section>

          <section class="card">
            <h3>文章结构</h3>
            <ul class="outline" id="outline"><li>尚未识别标题</li></ul>
          </section>

          <section class="card">
            <h3>适配检查</h3>
            <div class="checks">
              <div class="check"><span>正文字符</span><strong id="char-count">0</strong></div>
              <div class="check"><span>预计阅读</span><strong id="read-time">0 分钟</strong></div>
              <div class="check"><span>接口 HTML（参考）</span><strong id="html-count">0</strong></div>
              <div class="check"><span>外部链接</span><strong id="link-count">0</strong></div>
              <div class="check"><span>行间 / 行内公式</span><strong id="formula-count">0 / 0</strong></div>
              <div class="check"><span>正文图片</span><strong id="image-count">0</strong></div>
              <div class="check"><span>标题 / 摘要</span><strong id="meta-count">0 / 0</strong></div>
            </div>
            <p class="audit-message" id="audit-message"></p>
          </section>

          <section class="card">
            <div class="card-title-row">
              <h3>本地版本</h3>
              <button class="text-button" id="save-snapshot" type="button">保存快照</button>
            </div>
            <select id="snapshot-select" aria-label="历史快照"><option value="">暂无快照</option></select>
            <button class="button button--wide" id="restore-snapshot" type="button">恢复所选版本</button>
          </section>

          <section class="card">
            <h3>发布前注意</h3>
            <ul class="notes">
              <li>编辑器用 KaTeX 预览，复制时生成微信兼容 SVG，接口模式可生成公式图片。</li>
              <li>接口 HTML 体积仅供参考，长度是否可接受以微信接口实际返回结果为准。</li>
              <li>本地或剪贴板图片会嵌入 Markdown，发布前检查清晰度和版权。</li>
              <li>接口草稿模式仍可按需将公式转图，最终以手机预览为准。</li>
            </ul>
          </section>
        </aside>

        <section class="panel editor">
          <div class="panel__head">
            <h2>Markdown</h2>
            <span class="status" id="save-status">本地自动保存</span>
          </div>
          <div class="toolbar" aria-label="Markdown 工具栏">
            <button data-prefix="## " type="button" title="二级标题">H2</button>
            <button data-prefix="### " type="button" title="三级标题">H3</button>
            <button data-wrap="**" type="button" title="加粗"><strong>B</strong></button>
            <button data-wrap="*" type="button" title="斜体"><em>I</em></button>
            <button data-prefix="> " type="button" title="引用">❞</button>
            <button data-prefix="- " type="button" title="无序列表">•</button>
            <button data-prefix="1. " type="button" title="有序列表">1.</button>
            <button data-link type="button" title="链接">链接</button>
            <button data-inline-math type="button" title="行内公式">$x$</button>
            <button data-block-math type="button" title="行间公式">$$</button>
            <button data-table type="button" title="表格">表格</button>
            <button data-divider type="button" title="分隔线">—</button>
            <label class="toolbar-file" title="插入图片">图片<input id="body-image-input" type="file" accept="image/*" multiple hidden /></label>
          </div>
          <textarea id="markdown" spellcheck="true" aria-label="Markdown 正文"></textarea>
          <p class="editor-hint">可直接粘贴或拖入图片。Ctrl/Cmd + S 保存快照，Ctrl/Cmd + Shift + C 复制富文本。</p>
        </section>

        <section class="panel preview-panel">
          <div class="panel__head">
            <h2>公众号预览</h2>
            <span class="status" id="preview-status">KaTeX 预览</span>
          </div>
          <div class="preview-wrap">
            <article class="phone" id="phone">
              <img class="article-cover" id="cover-preview" alt="" />
              <p class="cover-caption" id="caption-preview"></p>
              <div class="rich" id="preview"></div>
            </article>
          </div>
        </section>
      </section>
    </main>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <script>
      import DOMPurify from "dompurify";
      import katex from "katex";
      import { marked } from "marked";

      const $ = <T extends HTMLElement>(selector: string) => document.querySelector<T>(selector)!;
      const input = $("#markdown") as HTMLTextAreaElement;
      const preview = $("#preview");
      const phone = $("#phone");
      const titleInput = $("#title") as HTMLInputElement;
      const authorInput = $("#author") as HTMLInputElement;
      const digestInput = $("#digest") as HTMLTextAreaElement;
      const sourceInput = $("#source-url") as HTMLInputElement;
      const captionInput = $("#cover-caption") as HTMLTextAreaElement;
      const accentInput = $("#accent") as HTMLInputElement;
      const themeInput = $("#theme") as HTMLSelectElement;
      const linkModeInput = $("#link-mode") as HTMLSelectElement;
      const coverInput = $("#cover-input") as HTMLInputElement;
      const coverPreview = $("#cover-preview") as HTMLImageElement;
      const captionPreview = $("#caption-preview");
      const snapshotSelect = $("#snapshot-select") as HTMLSelectElement;
      const helperStatus = $("#helper-status");
      const helperDetail = $("#helper-detail");
      const helperPreviewButton = $("#draft-preview") as HTMLButtonElement;
      const helperSubmitButton = $("#draft-submit") as HTMLButtonElement;
      const updateMediaInput = $("#update-media-id") as HTMLInputElement;
      const appIdInput = $("#wechat-app-id") as HTMLInputElement;
      const appSecretInput = $("#wechat-app-secret") as HTMLInputElement;
      const publicIpInput = $("#public-ip") as HTMLInputElement;
      const saveWechatConfigButton = $("#save-wechat-config") as HTMLButtonElement;
      const queryPublicIpButton = $("#query-public-ip") as HTMLButtonElement;
      const HELPER_URL = "http://127.0.0.1:4399";
      const STORAGE = "sencium-wechat-editor-v2";
      const SNAPSHOTS = "sencium-wechat-editor-snapshots-v1";
      const ASSET_SCHEME = "mp-asset://";
      const ASSET_DB = "sencium-mp-editor-assets";
      const assetBlobs = new Map<string, Blob>();
      const assetObjectUrls = new Map<string, string>();
      const themeColors: Record<string, string> = {
        ink: "#0b1015", red: "#8c2f2b", blue: "#164d76", green: "#315f50",
      };
      const initial = `> 在这里写导语。编辑器会直接渲染并复制 KaTeX 公式。

## 一、第一个问题

正文支持 **强调**、列表、表格、引用与行内公式 $W_2(\\mu,\\nu)$。

$$
W_2^2(\\mu,\\nu)=\\inf_{\\pi\\in\\Pi(\\mu,\\nu)}\\int d(x,y)^2\\,d\\pi(x,y).
$$

## 二、结论

完整材料见 **阅读原文**。`;

      marked.setOptions({ gfm: true, breaks: false });

      const showToast = (message: string) => {
        const toast = $("#toast");
        toast.textContent = message;
        toast.classList.add("is-visible");
        window.setTimeout(() => toast.classList.remove("is-visible"), 2200);
      };

      const parseFrontmatter = (text: string) => {
        const match = text.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n/);
        if (!match) return { body: text, fields: {} as Record<string, string> };
        const fields: Record<string, string> = {};
        for (const line of match[1].split(/\r?\n/)) {
          const index = line.indexOf(":");
          if (index > 0) fields[line.slice(0, index).trim()] = line.slice(index + 1).trim().replace(/^["']|["']$/g, "");
        }
        return { body: text.slice(match[0].length), fields };
      };

      const openAssetDb = () => new Promise<IDBDatabase>((resolve, reject) => {
        const request = indexedDB.open(ASSET_DB, 1);
        request.onupgradeneeded = () => request.result.createObjectStore("assets", { keyPath: "id" });
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
      });

      const saveAsset = async (id: string, blob: Blob, name: string) => {
        const db = await openAssetDb();
        await new Promise<void>((resolve, reject) => {
          const transaction = db.transaction("assets", "readwrite");
          transaction.objectStore("assets").put({ id, blob, name, type: blob.type, updatedAt: Date.now() });
          transaction.oncomplete = () => resolve();
          transaction.onerror = () => reject(transaction.error);
        });
        db.close();
        assetBlobs.set(id, blob);
        if (assetObjectUrls.has(id)) URL.revokeObjectURL(assetObjectUrls.get(id)!);
        assetObjectUrls.set(id, URL.createObjectURL(blob));
      };

      const loadAssets = async () => {
        const db = await openAssetDb();
        const assets = await new Promise<any[]>((resolve, reject) => {
          const request = db.transaction("assets", "readonly").objectStore("assets").getAll();
          request.onsuccess = () => resolve(request.result);
          request.onerror = () => reject(request.error);
        });
        db.close();
        assets.forEach((asset) => {
          assetBlobs.set(asset.id, asset.blob);
          assetObjectUrls.set(asset.id, URL.createObjectURL(asset.blob));
        });
      };

      const blobToDataUrl = (blob: Blob) => new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result));
        reader.onerror = () => reject(reader.error);
        reader.readAsDataURL(blob);
      });

      const migrateEmbeddedImages = async (markdown: string) => {
        const matches = [...new Set(markdown.match(/data:image\/[a-zA-Z0-9.+-]+;base64,[a-zA-Z0-9+/=]+/g) || [])];
        let migrated = markdown;
        for (const dataUrl of matches) {
          const id = crypto.randomUUID();
          const blob = await (await fetch(dataUrl)).blob();
          await saveAsset(id, blob, `pasted-${id}`);
          migrated = migrated.replaceAll(dataUrl, `${ASSET_SCHEME}${id}`);
        }
        return migrated;
      };

      const markdownForRender = (markdown: string) => markdown.replace(
        /mp-asset:\/\/([a-zA-Z0-9-]+)/g,
        (_, id) => `https://mp-editor.local/assets/${id}`,
      );

      const markdownForExport = async (markdown: string) => {
        let exported = markdown;
        for (const id of [...new Set(markdown.match(/mp-asset:\/\/([a-zA-Z0-9-]+)/g) || [])].map((item) => item.slice(ASSET_SCHEME.length))) {
          const blob = assetBlobs.get(id);
          if (blob) exported = exported.replaceAll(`${ASSET_SCHEME}${id}`, await blobToDataUrl(blob));
        }
        return exported;
      };

      const applyStyle = (root: HTMLElement, selector: string, cssText: string) => {
        root.querySelectorAll<HTMLElement>(selector).forEach((element) => {
          element.style.cssText = `${element.style.cssText};${cssText}`;
        });
      };

      const applyArticleStyles = () => {
        const accent = accentInput.value;
        preview.style.cssText = "color:#242927;background:#fff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Microsoft YaHei',sans-serif;font-size:14px;line-height:1.75;";
        applyStyle(preview, "h1", `display:table;max-width:calc(100% - 24px);box-sizing:border-box;margin:0 auto 26px;padding:0 4px 7px;border-bottom:2px solid ${accent};color:#1f2522;text-align:center;font-size:21px;line-height:1.45;font-weight:700;`);
        applyStyle(preview, "h2", `display:table;margin:32px auto 16px;padding:7px 14px;border-radius:6px;background:${accent};color:#fff;font-size:17px;line-height:1.5;font-weight:700;`);
        applyStyle(preview, "h3", `margin:26px 0 11px;padding:6px 10px;border-left:4px solid ${accent};background:#f3f5f4;color:#202523;font-size:15px;line-height:1.55;font-weight:700;`);
        applyStyle(preview, "p", "margin:0 0 14px;color:#303633;font-size:14px;line-height:1.75;text-align:justify;letter-spacing:.01em;");
        applyStyle(preview, "strong", `display:inline;color:${accent};font-weight:700;`);
        applyStyle(preview, "blockquote", `margin:16px 0 20px;padding:11px 14px;border-left:3px solid ${accent};background:#f3f1ec;color:#555b57;`);
        applyStyle(preview, "blockquote p", "margin:0;color:#555b57;font-size:14px;line-height:1.75;");
        applyStyle(preview, "ul", "margin:10px 0 18px;padding-left:23px;");
        applyStyle(preview, "ol", "margin:10px 0 18px;padding-left:25px;");
        applyStyle(preview, "li", "margin:5px 0;padding-left:2px;color:#303633;font-size:14px;line-height:1.75;text-align:justify;");
        applyStyle(preview, ".list-item-content", "display:inline;color:inherit;font-size:inherit;line-height:inherit;");
        applyStyle(preview, "a", `color:${accent};text-decoration:none;border-bottom:1px solid ${accent};`);
        applyStyle(preview, ".article-divider", "display:block;margin:29px auto 27px;padding:0;text-align:center;font-size:0;line-height:0;");
        applyStyle(preview, ".article-divider-line", `display:inline-block;width:34px;margin:0 9px;border-top:1px solid ${accent};vertical-align:middle;opacity:.55;`);
        applyStyle(preview, ".article-divider-mark", `display:inline-block;color:${accent};font-size:8px;line-height:1;vertical-align:middle;opacity:.8;`);
        applyStyle(preview, "code:not(pre code)", "padding:1px 4px;border-radius:3px;background:#f0f2f1;color:#9a3d36;font-family:Consolas,monospace;font-size:13px;");
        applyStyle(preview, "pre", "margin:16px 0;padding:14px 16px;overflow-x:auto;background:#222725;color:#edf1ef;font-size:12px;line-height:1.65;border-radius:4px;white-space:pre-wrap;");
        applyStyle(preview, "img", "display:block;max-width:100%;height:auto;margin:18px auto;border:0;");
        applyStyle(preview, "table", "width:100%;margin:16px auto 24px;border-collapse:collapse;font-size:13px;line-height:1.55;");
        applyStyle(preview, "th", `padding:8px 6px;border-bottom:2px solid ${accent};color:${accent};text-align:left;font-weight:700;`);
        applyStyle(preview, "td", "padding:8px 6px;border-bottom:1px solid #e2e5e3;color:#303633;text-align:left;vertical-align:top;");
        applyStyle(preview, ".formula-block", "margin:0;padding:0;overflow-x:auto;color:#1d2421;text-align:center;font-size:16px;line-height:1.6;");
        applyStyle(preview, ".formula-inline", "display:inline-block;margin:0 2px;color:#1d2421;font-size:1em;line-height:1.2;vertical-align:-.15em;");
        applyStyle(preview, ".link-notes", "margin-top:32px;padding-top:12px;border-top:1px solid #dfe3e0;color:#69706c;font-size:12px;");
      };

      const render = () => {
        const { body: sourceBody } = parseFrontmatter(input.value);
        const body = markdownForRender(sourceBody);
        const blocks: string[] = [];
        const inlines: string[] = [];
        const blockProtected = body.replace(/\$\$([\s\S]*?)\$\$/g, (_, math) => {
          const index = blocks.push(math.trim()) - 1;
          return `\n<section data-math-block="${index}"></section>\n`;
        });
        const mathProtected = blockProtected.replace(/(?<!\\)\$([^$\n]+?)(?<!\\)\$/g, (_, math) => {
          const index = inlines.push(math.trim()) - 1;
          return `<span data-math-inline="${index}"></span>`;
        });
        const clean = DOMPurify.sanitize(marked.parse(mathProtected, { async: false }) as string, {
          USE_PROFILES: { html: true },
          ADD_ATTR: ["data-math-block", "data-math-inline"],
        });
        preview.innerHTML = clean;

        preview.querySelectorAll<HTMLElement>("[data-math-block]").forEach((node) => {
          const math = blocks[Number(node.dataset.mathBlock)];
          node.className = "formula-block";
          node.dataset.mathSource = math;
          try {
            katex.render(math, node, { displayMode: true, throwOnError: false, strict: "ignore", output: "htmlAndMathml" });
          } catch {
            node.textContent = math;
          }
        });
        preview.querySelectorAll<HTMLElement>("[data-math-inline]").forEach((node) => {
          const math = inlines[Number(node.dataset.mathInline)];
          node.className = "formula-inline";
          node.dataset.mathSource = math;
          try {
            katex.render(math, node, { displayMode: false, throwOnError: false, strict: "ignore", output: "htmlAndMathml" });
          } catch {
            node.textContent = math;
          }
        });

        preview.querySelectorAll<HTMLImageElement>('img[src^="https://mp-editor.local/assets/"]').forEach((image) => {
          const id = image.src.split("/").pop() || "";
          const objectUrl = assetObjectUrls.get(id);
          if (objectUrl) {
            image.src = objectUrl;
            image.dataset.assetId = id;
          }
        });

        preview.querySelectorAll<HTMLLIElement>("li").forEach((item) => {
          const paragraphs = [...item.children].filter((child) => child.tagName === "P") as HTMLParagraphElement[];
          paragraphs.forEach((paragraph, index) => {
            if (index > 0) paragraph.before(document.createElement("br"));
            while (paragraph.firstChild) item.insertBefore(paragraph.firstChild, paragraph);
            paragraph.remove();
          });
          const hasNestedList = [...item.children].some((child) => child.tagName === "UL" || child.tagName === "OL");
          if (!hasNestedList) {
            const content = document.createElement("span");
            content.className = "list-item-content";
            while (item.firstChild) content.append(item.firstChild);
            item.append(content);
          }
        });

        preview.querySelectorAll("hr").forEach((rule) => {
          const divider = document.createElement("section");
          divider.className = "article-divider";
          const left = document.createElement("span");
          left.className = "article-divider-line";
          const mark = document.createElement("span");
          mark.className = "article-divider-mark";
          mark.textContent = "◆";
          const right = document.createElement("span");
          right.className = "article-divider-line";
          divider.append(left, mark, right);
          rule.replaceWith(divider);
        });

        const externalLinks: { text: string; href: string }[] = [];
        preview.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
          if (/^https?:/i.test(link.href)) externalLinks.push({ text: link.textContent || link.href, href: link.href });
          if (linkModeInput.value === "text") link.replaceWith(document.createTextNode(link.textContent || ""));
          else {
            link.target = "_blank";
            link.rel = "noreferrer noopener";
          }
        });
        if (linkModeInput.value === "footnote" && externalLinks.length) {
          const notes = document.createElement("section");
          notes.className = "link-notes";
          notes.innerHTML = `<strong>文中链接</strong><ol>${externalLinks.map((item) => `<li>${DOMPurify.sanitize(item.text)}：${DOMPurify.sanitize(item.href)}</li>`).join("")}</ol>`;
          preview.append(notes);
          preview.querySelectorAll("a").forEach((link) => link.replaceWith(document.createTextNode(link.textContent || "")));
        }
        applyArticleStyles();
        document.documentElement.style.setProperty("--accent", accentInput.value);
        captionPreview.innerHTML = "";
        const captionText = document.createElement("span");
        captionText.textContent = captionInput.value;
        captionText.style.cssText = "color:#777e7a;font-size:11px;line-height:1.55;font-weight:400;letter-spacing:0;text-align:left;";
        captionPreview.append(captionText);
        captionPreview.style.cssText = "display:block;margin:0 0 22px;padding:0;color:#777e7a;font-size:11px;line-height:1.55;text-align:left;";
        coverPreview.style.cssText = `${coverPreview.style.cssText};display:${coverPreview.classList.contains("is-visible") ? "block" : "none"};width:100%;max-width:677px;height:auto;margin:0 auto 5px;border:0;`;

        const headings = [...preview.querySelectorAll("h2")];
        $("#outline").innerHTML = headings.length ? headings.map((heading) => `<li>${heading.textContent}</li>`).join("") : "<li>尚未识别标题</li>";
        const charCount = (preview.textContent || "").replace(/\s+/g, "").length;
        const linkCount = (sourceBody.match(/\[[^\]]+\]\(https?:\/\/[^)]+\)|https?:\/\/\S+/g) || []).length;
        const imageCount = preview.querySelectorAll("img").length;
        const htmlCount = phone.outerHTML.length;
        $("#char-count").textContent = charCount.toLocaleString("zh-CN");
        $("#read-time").textContent = `${Math.max(1, Math.ceil(charCount / 500))} 分钟`;
        $("#html-count").textContent = htmlCount.toLocaleString("zh-CN");
        $("#link-count").textContent = String(linkCount);
        $("#formula-count").textContent = `${blocks.length} / ${inlines.length}`;
        $("#image-count").textContent = String(imageCount);
        $("#meta-count").textContent = `${titleInput.value.length} / ${digestInput.value.length}`;
        $("#char-count").className = "ok";
        $("#html-count").className = "ok";
        $("#link-count").className = linkCount === 0 || linkModeInput.value !== "keep" ? "ok" : "warn";
        $("#meta-count").className = titleInput.value.length <= 64 && digestInput.value.length <= 120 ? "ok" : "warn";
        const issues = [
          titleInput.value.length > 64 && "标题超过 64 字",
          digestInput.value.length > 120 && "摘要超过 120 字",
          linkModeInput.value === "keep" && linkCount > 0 && "公众号可能过滤正文外链",
        ].filter(Boolean);
        $("#audit-message").textContent = issues.length ? issues.join("；") : "未发现明显的公众号兼容问题。";
