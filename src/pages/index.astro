      $("[data-link]").addEventListener("click", () => replaceSelection("[", "](https://example.com)", "链接文字"));
      $("[data-inline-math]").addEventListener("click", () => replaceSelection("$", "$", "x"));
      $("[data-block-math]").addEventListener("click", () => replaceSelection("\n\n$$\n", "\n$$\n\n", "\\int f(x)\\,dx"));
      $("[data-table]").addEventListener("click", () => insertAtCursor("\n\n| 项目 | 内容 |\n| --- | --- |\n| A | 示例 |\n\n"));
      $("[data-divider]").addEventListener("click", () => insertAtCursor("\n\n---\n\n"));
      document.querySelectorAll<HTMLButtonElement>("[data-width]").forEach((button) => {
        button.addEventListener("click", () => {
          document.querySelectorAll("[data-width]").forEach((item) => item.classList.remove("is-active"));
